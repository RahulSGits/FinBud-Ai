generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model Organization {
  id               String               @id @default(uuid())
  name             String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  agents           Agent[]
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]
  callLogs         CallLog[]
  campaigns        Campaign[]
  contacts         Contact[]
  integrations     Integration[]
  knowledgeBases   KnowledgeBase[]
  phoneNumbers     PhoneNumber[]
  settings         Settings?
  users            User[]
  whatsappLogs     WhatsAppMessageLog[]
  whatsappSettings WhatsAppSettings?
}

model User {
  id             String        @id @default(uuid())
  organizationId String?
  email          String        @unique
  password       String
  fullName       String
  role           String        @default("member")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  auditLogs      AuditLog[]
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Agent {
  id                String             @id @default(uuid())
  organizationId    String
  name              String
  description       String?
  // Voice orchestration provider: vapi | omnidimension | mock
  provider          String             @default("vapi")
  // Provider-side agent id (Vapi assistant UUID, OmniDimension integer id, ...)
  externalAgentId   String?
  sttProvider       String?
  sttModel          String?
  llmProvider       String             @default("openai")
  model             String             @default("gpt-4o")
  temperature       Float              @default(0.7)
  maxTokens         Int                @default(1000)
  voiceProvider     String             @default("elevenlabs")
  voiceId           String
  language          String             @default("en")
  firstMessage      String?
  status            String             @default("active")
  silenceTimeout    Int                @default(3000)
  interruptions     Boolean            @default(true)
  transferEnabled   Boolean            @default(false)
  transferNumber    String?
  vapiAssistantId   String?
  systemPrompt      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  callLogs          CallLog[]
  campaigns         Campaign[]
  prompts           PromptVersion[]
  whatsappTemplates WhatsAppTemplate[]
  knowledgeBases    KnowledgeBase[]    @relation("AgentToKnowledgeBase")
}

model PromptVersion {
  id                  String   @id @default(uuid())
  agentId             String
  version             Int      @default(1)
  systemPrompt        String
  businessContext     String?
  callObjective       String?
  qualificationRules  String?
  closingInstructions String?
  fallbackRules       String?
  complianceRules     String?
  isActive            Boolean  @default(false)
  createdAt           DateTime @default(now())
  agent               Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model KnowledgeBase {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  documents      Document[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agents         Agent[]      @relation("AgentToKnowledgeBase")
}

model Document {
  id              String              @id @default(uuid())
  knowledgeBaseId String
  type            String
  name            String
  content         String
  status          String              @default("processing")
  createdAt       DateTime            @default(now())
  knowledgeBase   KnowledgeBase       @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  embeddings      DocumentEmbedding[]
}

model DocumentEmbedding {
  id         String                 @id @default(uuid())
  documentId String
  content    String
  embedding  Unsupported("vector")?
  createdAt  DateTime               @default(now())
  document   Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Campaign {
  id             String       @id @default(uuid())
  organizationId String
  agentId        String
  name           String
  // draft | scheduled | running | paused | completed
  status         String       @default("draft")
  // JSON: { tz, days:[0-6], start:"09:00", end:"18:00" }
  businessHours  String?
  // Max calls per calendar day (null = unlimited)
  callLimits     Int?
  scheduledAt    DateTime?
  // Max simultaneous in-flight calls
  concurrency    Int          @default(1)
  // Retry policy for unanswered / failed contacts
  retryLimit     Int          @default(0)
  retryDelayMins Int          @default(60)
  totalContacts  Int          @default(0)
  completedCalls Int          @default(0)
  failedCalls    Int          @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  lastTickAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  callLogs       CallLog[]
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
}

model Contact {
  id             String               @id @default(uuid())
  organizationId String
  campaignId     String?
  name           String?
  phone          String
  email          String?
  company        String?
  loanAmount     Float?
  loanType       String?
  // pending | calling | completed | failed | exhausted
  status         String               @default("pending")
  // Retry bookkeeping for the campaign runner
  attempts       Int                  @default(0)
  lastAttemptAt  DateTime?
  nextAttemptAt  DateTime?
  customFields   String?
  notes          String?
  tags           String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  callLogs       CallLog[]
  campaign       Campaign?            @relation(fields: [campaignId], references: [id])
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  whatsappLogs   WhatsAppMessageLog[]
}

model CallLog {
  id             String               @id @default(uuid())
  organizationId String
  agentId        String?
  campaignId     String?
  contactId      String?
  phone          String
  direction      String               @default("outbound")
  status         String               @default("completed")
  providerCallId String?              @unique
  duration       Int                  @default(0)
  cost           Float                @default(0)
  outcome        String?
  interested     Boolean              @default(false)
  leadStatus     String?
  followUp       Boolean              @default(false)
  sentiment      String?
  exotelCallSid  String?
  leadScore      Int?
  recordingUrl   String?
  transcript     String?
  summary        String?
  customerIntent String?
  nextAction     String?
  objections     String?
  startedAt      DateTime             @default(now())
  endedAt        DateTime?
  callEvents     CallEvent[]
  agent          Agent?               @relation(fields: [agentId], references: [id])
  campaign       Campaign?            @relation(fields: [campaignId], references: [id])
  contact        Contact?             @relation(fields: [contactId], references: [id])
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  callTranscript CallTranscript?
  whatsappLogs   WhatsAppMessageLog[]
}

model CallEvent {
  id        String   @id @default(uuid())
  callLogId String
  type      String
  payload   String?
  createdAt DateTime @default(now())
  callLog   CallLog  @relation(fields: [callLogId], references: [id], onDelete: Cascade)
}

model CallTranscript {
  id           String   @id @default(uuid())
  callLogId    String   @unique
  transcript   String?
  messagesJson String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  callLog      CallLog  @relation(fields: [callLogId], references: [id], onDelete: Cascade)
}

model PhoneNumber {
  id             String       @id @default(uuid())
  organizationId String
  number         String
  provider       String       @default("twilio")
  sid            String?
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Integration {
  id             String       @id @default(uuid())
  organizationId String
  type           String
  config         String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id             String       @id @default(uuid())
  organizationId String
  provider       String
  keyEncrypted   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  resource       String
  details        String?
  ipAddress      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])
}

model Settings {
  id             String       @id @default(uuid())
  organizationId String       @unique
  theme          String       @default("system")
  timezone       String       @default("UTC")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WhatsAppSettings {
  id             String       @id @default(uuid())
  organizationId String       @unique
  apiKey         String
  apiToken       String
  accountSid     String
  subdomain      String       @default("api.exotel.com")
  whatsappNumber String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WhatsAppTemplate {
  id             String   @id @default(uuid())
  agentId        String
  triggerOutcome String
  templateName   String?
  messageBody    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model WhatsAppMessageLog {
  id             String       @id @default(uuid())
  organizationId String
  contactId      String?
  callLogId      String?
  recipientPhone String
  templateName   String?
  messageBody    String?
  status         String       @default("sent")
  error          String?
  messageId      String?
  createdAt      DateTime     @default(now())
  callLog        CallLog?     @relation(fields: [callLogId], references: [id])
  contact        Contact?     @relation(fields: [contactId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
