# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:pass@host:5432/postgres"
DIRECT_URL="postgresql://user:pass@host:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Public base URL. Used to build the webhook URL handed to voice providers,
# so calls can report status/transcripts back. Must be https and reachable.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Mock mode
# ---------------------------------------------------------------------------
# When true, every voice provider resolves to the built-in mock adapter:
# no external API calls, no spend, no telephony. Calls are simulated end to end
# (status -> transcript -> summary/outcome) so campaigns, call logs, analytics
# and WhatsApp automation can be exercised with zero paid keys.
USE_MOCK_DATA=false

# ---------------------------------------------------------------------------
# Voice orchestration providers
# ---------------------------------------------------------------------------
# Vapi handles telephony + STT/LLM/TTS routing. https://vapi.ai
VAPI_API_KEY=""
VAPI_PHONE_NUMBER_ID=""

# OmniDimension — alternative provider, also sells +91 (India) numbers directly.
OMNIDIM_API_KEY=""

# ---------------------------------------------------------------------------
# Bring-your-own provider keys (optional)
# ---------------------------------------------------------------------------
# Only needed if you want your own billing / specific models. Vapi and
# OmniDimension can manage the speech pipeline themselves, so leave these blank
# until you have a concrete quality or cost reason to take them over.
OPENAI_API_KEY=""
DEEPGRAM_API_KEY=""
ELEVENLABS_API_KEY=""
SARVAM_API_KEY=""
